{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    /* Module system */
    "module": "commonjs",
    "moduleResolution": "node",
    /* Project structure */
    "rootDir": "src",
    "outDir": "dist",
    /* Interop & imports */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    /* Type safety */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    /* Quality of life */
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}